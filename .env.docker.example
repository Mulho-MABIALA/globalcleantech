# ── Global Clean Tech — variables pour le déploiement Docker (VPS Jokko) ─────
# Copiez ce fichier en ".env" à la racine du projet sur le serveur, puis
# remplissez les valeurs réelles. Ce fichier ".env" ne doit JAMAIS être commité
# (déjà exclu par .gitignore).
#
# Utilisé à la fois par docker-compose.yml (substitution ${...}) et injecté
# dans le conteneur "app" via env_file.

# ── PostgreSQL (conteneur "db") ──────────────────────────────────────────────
POSTGRES_USER=gct
POSTGRES_PASSWORD=change_this_to_a_strong_password
POSTGRES_DB=globalcleantech

# Doit pointer vers le service "db" (nom du service docker-compose, pas localhost)
# et reprendre exactement les mêmes identifiants que ci-dessus.
DATABASE_URL=postgresql://gct:change_this_to_a_strong_password@db:5432/globalcleantech

# ── Backend ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=8h

# Domaine public final (utilisé pour CORS, liens dans les emails, etc.)
FRONTEND_URL=https://globalcleantechsn.com

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── SMTP (emails) ─────────────────────────────────────────────────────────────
MAIL_HOST=mail.globalcleantechsn.com
MAIL_PORT=465
MAIL_USER=contact@globalcleantechsn.com
MAIL_PASS=
MAIL_FROM="Global Clean Tech <contact@globalcleantechsn.com>"
MAIL_ADMIN=contact@globalcleantechsn.com

# ── Notifications push (web push) — npx web-push generate-vapid-keys ────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@globalcleantechsn.com

# ── Connexion Google ──────────────────────────────────────────────────────────
# Pensez à ajouter https://globalcleantechsn.com dans les origines JavaScript
# autorisées du client OAuth (Google Cloud Console).
GOOGLE_CLIENT_ID=
