generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PosteSouhaite {
  femme_menage
  nounou
  cuisinier
  chauffeur
  gardien
  majordome
  autre
}

enum Experience {
  zero_un
  un_trois
  trois_cinq
  cinq_plus
}

enum StatutCandidature {
  a_traiter
  en_cours
  place
  archive
}

enum TypeDemandeur {
  particulier
  entreprise
  institution
}

enum ServiceSouhaite {
  placement
  impression
  redaction
  transfert
  communication
  autre
}

enum StatutDemande {
  nouvelle
  en_traitement
  cloturee
}

enum RoleUser {
  admin
  gestionnaire
}

enum StatutMessage {
  non_lu
  lu
  archive
}

model Actualite {
  id          Int      @id @default(autoincrement())
  titre       String   @db.VarChar(200)
  description String   @db.Text
  categorie   String   @db.VarChar(80)
  couleur     String   @default("emerald") @db.VarChar(50)
  icone       String   @default("star") @db.VarChar(50)
  lien        String?  @db.VarChar(255)
  ordre       Int      @default(0)
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          Int      @id @default(autoincrement())
  titre       String   @db.VarChar(150)
  description String   @db.Text
  emoji       String   @db.VarChar(10)
  couleur     String   @db.VarChar(100)
  tags        String   @db.VarChar(255)
  ordre       Int      @default(0)
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  email      String   @unique @db.VarChar(150)
  password   String
  role       RoleUser @default(gestionnaire)
  avatarPath String?  @db.VarChar(255)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Candidature {
  id                Int               @id @default(autoincrement())
  nomComplet        String            @db.VarChar(150)
  dateNaissance     DateTime          @db.Date
  telephone         String            @db.VarChar(20)
  email             String?           @db.VarChar(150)
  ville             String            @db.VarChar(100)
  posteSouhaite     PosteSouhaite
  experience        Experience
  description       String?           @db.Text
  cvPath            String?           @db.VarChar(255)
  photoPath         String?           @db.VarChar(255)
  cniRectoPath      String?           @db.VarChar(255)
  cniVersoPath      String?           @db.VarChar(255)
  disponibilite     String            @db.VarChar(100)
  dateDisponibilite DateTime?         @db.Date
  statut            StatutCandidature @default(a_traiter)
  notesInternes     String?           @db.Text
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  placements        Placement[]
}

model Message {
  id        Int           @id @default(autoincrement())
  nom       String        @db.VarChar(150)
  email     String        @db.VarChar(150)
  telephone String?       @db.VarChar(20)
  sujet     String        @db.VarChar(200)
  corps     String        @db.Text
  statut    StatutMessage @default(non_lu)
  noteAdmin String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Temoignage {
  id        Int      @id @default(autoincrement())
  nom       String   @db.VarChar(100)
  role      String   @db.VarChar(100)
  texte     String   @db.Text
  note      Int      @default(5)
  actif     Boolean  @default(true)
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Placement {
  id            Int         @id @default(autoincrement())
  candidatureId Int
  candidature   Candidature @relation(fields: [candidatureId], references: [id], onDelete: Cascade)
  demandeId     Int?
  demande       Demande?    @relation(fields: [demandeId], references: [id], onDelete: SetNull)
  dateDebut     DateTime    @db.Date
  dateFin       DateTime?   @db.Date
  salaire       String?     @db.VarChar(100)
  notes         String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model NewsletterSubscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(150)
  nom       String?  @db.VarChar(100)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SiteContent {
  id        Int      @id @default(autoincrement())
  cle       String   @unique @db.VarChar(100)
  valeur    String   @db.Text
  updatedAt DateTime @updatedAt
}

model Demande {
  id               Int             @id @default(autoincrement())
  nomRaisonSociale String          @db.VarChar(150)
  typeDemandeur    TypeDemandeur
  telephone        String          @db.VarChar(20)
  email            String          @db.VarChar(150)
  serviceSouhaite  ServiceSouhaite
  posteRecherche   String?         @db.VarChar(100)
  nombrePersonnes  Int?
  description      String          @db.Text
  budgetEstime     String?         @db.VarChar(100)
  dateSouhaitee    DateTime?       @db.Date
  statut           StatutDemande   @default(nouvelle)
  notesInternes    String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  placements       Placement[]
}
